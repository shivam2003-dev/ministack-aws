# MiniStack AWS - Environment Configuration
# Copy to .env and customize as needed

# AWS CLI Configuration (use with: export $(cat .env | xargs))
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Database Configuration
RDS_HOST=localhost
RDS_PORT=15432
RDS_USER=admin
RDS_PASSWORD=admin123
RDS_DB=postgres

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=16379

# MinIO Console
MINIO_ENDPOINT=http://localhost:9001
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# MiniStack Configuration (for advanced use)
DEBUG=0
SERVICES=s3,lambda,dynamodb,sqs,sns,iam,apigateway,cognito-idp,cloudformation,logs,ssm,kms,secretsmanager,stepfunctions,events,kinesis,firehose,route53,ses,acm,wafv2,appync,ecr,ecs,rds,elasticache,glue,athena,ec2,cloudfront
